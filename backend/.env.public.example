# Example environment file for public (read-only) deployment.
# The app does not auto-load this file by name; copy values into your actual
# environment source (systemd EnvironmentFile, container env vars, etc.).
APP_MODE=public

# Comma-separated, no spaces unless part of URL.
CORS_ORIGINS=https://tree.example.com

# Public instances should keep docs disabled.
ENABLE_API_DOCS=false

# Optional additional app-layer limiter.
RATE_LIMIT_PER_MINUTE=120

# Optional hard lock for admin-only operations in admin mode.
ADMIN_API_KEY=
